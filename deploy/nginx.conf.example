# Örnek Nginx yapılandırması.
# TLS'i Nginx termine eder; uygulama düz HTTP dinler.

server {
    listen 443 ssl;
    server_name portal.example.local;

    ssl_certificate     /etc/nginx/certs/portal.crt;
    ssl_certificate_key /etc/nginx/certs/portal.key;

    # Frontend (Vite build çıktısı: frontend/dist)
    root /var/www/portal;
    index index.html;

    # SPA fallback
    location / {
        try_files $uri /index.html;
    }

    # Backend API
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /healthz {
        proxy_pass http://127.0.0.1:8000;
    }
}

# HTTP -> HTTPS yönlendirme
server {
    listen 80;
    server_name portal.example.local;
    return 301 https://$host$request_uri;
}
