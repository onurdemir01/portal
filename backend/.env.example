# ------------------------------------------------------------------
# Bu dosyayı ".env" olarak KOPYALAYIN ve değerleri doldurun.
# .env dosyasını ASLA git'e commit etmeyin (.gitignore'da olmalı).
# Prod'da bu değerleri OpenShift Secret veya Vault ile sağlayın.
# ------------------------------------------------------------------

# Oturum imzalama anahtarı — uzun, rastgele bir değer üretin:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=change-me-to-a-long-random-secret

# --- LDAP / Active Directory ---
LDAP_SERVER=adds.fw.garanti.com.tr
LDAP_PORT=3269
LDAP_USE_SSL=true
LDAP_BIND_DN=CN=srv_wasbindusr,OU=Service Users,OU=System Users,OU=All Users,DC=fw,DC=garanti,DC=com,DC=tr
# Servis hesabı parolasını buraya .env'de girin (repoya değil):
LDAP_BIND_PASSWORD=__set_in_env__
LDAP_BASE_DN=DC=fw,DC=garanti,DC=com,DC=tr
LDAP_ADMIN_GROUP=CN=GT-Bulut Middleware Teknolojileri,OU=Garanti Teknoloji,OU=All Groups,DC=fw,DC=garanti,DC=com,DC=tr

# --- Nöbetçi API ---
NOBETCI_API_URL=https://gbnys.fw.garanti.com.tr/api/nobetkayit/list/2204/DEFAULT

# --- Dış istekler için proxy ve SSL ---
# Kurumsal proxy: iç API'ler ve internet buradan çıkar.
OUTBOUND_PROXY=http://tekprxv2.fw.garanti.com.tr:80
# Proxy TLS'i kendi CA'sıyla imzalıyorsa, kurumsal CA sertifika dosyası:
#   OUTBOUND_CA_BUNDLE=/etc/pki/tls/certs/ca-bundle.crt
# CA dosyasını veremiyorsan, doğrulamayı kapatmak için (iç ağ, pratik ama zayıf):
#   VERIFY_SSL=false
OUTBOUND_CA_BUNDLE=
VERIFY_SSL=false

# --- Envanter DB (SQL Server, ODBC Driver 18) ---
# Parolayı .env'de girin. Not: en güvenli kurulum read-only bir DB
# kullanıcısıdır (db_datareader). Custom Query özelliği uygulama katmanında
# SELECT-only ile sınırlıdır, ancak read-only kullanıcı ikinci ve daha güçlü
# savunmadır.
INVENTORY_ODBC_DSN=DRIVER={ODBC Driver 18 for SQL Server};SERVER=TBMWANSALS.fw.garanti.com.tr,1453;DATABASE=TBMWANS;UID=TBMWANS_usr;PWD=__set_in_env__;TrustServerCertificate=yes;

# --- Uygulama DB (feature-flag, tablo eşlemeleri, audit) ---
APP_DB_URL=sqlite:///./app_data/portal.db

# --- Ansible / AAP (Self-Servis) — bilgi verildiğinde doldurulacak ---
ANSIBLE_BASE_URL=
ANSIBLE_TOKEN=__set_in_env__
SELFSERVICE_FILES_ROOT=./selfservice_output
